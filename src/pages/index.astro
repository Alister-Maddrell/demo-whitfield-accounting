---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const services = [
  {
    title: 'Tax Planning & Compliance',
    description: 'Save thousands each year with proactive strategies that have put over $50M back in our clients\u2019 pockets. Individual, company, trust, and SMSF returns lodged on time, every time.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`,
    num: '01',
  },
  {
    title: 'Business Advisory',
    description: 'From structuring and succession planning to cash flow forecasting, we\u2019ve helped 200+ Sydney businesses scale profitably with clear financial data behind every decision.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`,
    num: '02',
  },
  {
    title: 'Bookkeeping & Payroll',
    description: 'Get your weekends back and never miss a compliance deadline. Accurate bookkeeping and payroll by Xero, MYOB, and QuickBooks certified professionals — from $499/month.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
    num: '03',
  },
  {
    title: 'Self-Managed Super Funds',
    description: 'Build retirement wealth on your terms. We handle SMSF setup, annual administration, and ATO compliance end-to-end — so you can focus on your investment strategy.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8"/><path d="M12 18V6"/></svg>`,
    num: '04',
  },
];

const testimonials = [
  {
    quote: 'Whitfield & Associates restructured our business and saved us $82,000 in tax in the first year alone. Their proactive approach means we never miss a deduction or a deadline.',
    name: 'Rebecca Chen',
    title: 'Director, Lumina Design Studio',
    initials: 'RC',
  },
  {
    quote: "We\u2019ve worked with three Sydney firms before finding Whitfield. They set up a trust structure that saves us $45,000 annually — and they actually understand construction cash flow.",
    name: 'Mark Davidson',
    title: 'CEO, Davidson Construction Group',
    initials: 'MD',
  },
  {
    quote: 'Setting up our $1.8M SMSF felt overwhelming until we spoke with Catherine\u2019s team. They handled everything from ATO compliance to investment strategy — saved us 20+ hours.',
    name: 'Dr. Priya Sharma',
    title: 'Orthopaedic Surgeon, Sydney CBD',
    initials: 'PS',
  },
];

const articles = [
  {
    category: 'Tax',
    title: '5 Tax Deductions Most Sydney Businesses Miss',
    excerpt: 'The average business owner leaves $8,000–$15,000 in legitimate deductions unclaimed each year.',
    date: '12 Feb 2026',
    readTime: '4 min',
    image: 'https://images.unsplash.com/photo-1554224155-6726b3ff858f?w=800&h=500&fit=crop',
    alt: 'Financial charts and data analysis',
  },
  {
    category: 'Business',
    title: 'Sole Trader, Company, or Trust?',
    excerpt: 'The wrong structure could cost you $20,000+ a year in unnecessary tax.',
    date: '28 Jan 2026',
    readTime: '6 min',
    image: 'https://images.unsplash.com/photo-1552664730-d307ca884978?w=800&h=500&fit=crop',
    alt: 'Business professionals in meeting',
  },
  {
    category: 'Super',
    title: 'SMSF Property Rules in 2026',
    excerpt: 'Updated ATO compliance rules every NSW fund holder needs to know.',
    date: '15 Jan 2026',
    readTime: '5 min',
    image: 'https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=800&h=500&fit=crop',
    alt: 'Modern office building',
  },
];
---

<Layout title="Sydney CBD Accountants | Tax, Advisory & SMSF | Whitfield & Associates">
  <Navbar />

  <!-- ═══ HERO — Booking-centric ═══ -->
  <section class="hero relative overflow-hidden">
    <div class="absolute inset-0" style="background-image: url('https://images.unsplash.com/photo-1506973035872-a4ec16b8e8d9?w=1920&h=1080&fit=crop&q=80'); background-size: cover; background-position: center 40%;"></div>
    <div class="absolute inset-0" style="background: linear-gradient(105deg, rgba(11,17,32,0.94) 0%, rgba(11,17,32,0.82) 40%, rgba(11,17,32,0.4) 70%, rgba(11,17,32,0.2) 100%);"></div>
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(11,17,32,0.2) 0%, transparent 30%, transparent 70%, rgba(11,17,32,0.7) 100%);"></div>

    <div class="relative flex-1 flex items-center">
      <div class="max-w-[1200px] w-full mx-auto px-6 lg:px-10 py-16">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
          <!-- Left: Copy -->
          <div class="lg:col-span-7">
            <div class="flex items-center gap-3 mb-7 reveal">
              <div class="w-8 h-[1.5px]" style="background: var(--color-gold-light);"></div>
              <span class="text-[0.6875rem] font-semibold tracking-[0.18em] uppercase" style="color: var(--color-gold-light);">Established 2008 · Sydney CBD</span>
            </div>

            <h1 class="reveal stagger-1 hero-text-shadow" style="color: #F8FAFC; line-height: 1.08;">
              Keep More of What<br class="hidden sm:block"> You Earn. <em>Grow What<br class="hidden sm:block"> You've Built.</em>
            </h1>

            <p class="text-[1.0625rem] md:text-[1.125rem] leading-[1.75] max-w-[520px] mt-7 reveal stagger-2 hero-text-shadow" style="color: rgba(226, 232, 240, 0.9);">
              Over $50M in tax saved for 200+ Sydney businesses. Proactive tax planning, business advisory, and bookkeeping from CPA-qualified partners.
            </p>

            <div class="mt-10 flex flex-col sm:flex-row gap-4 reveal stagger-3">
              <a href="/contact#booking" class="btn-primary">
                Book a Free Consultation
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
              <a href="#services" class="btn-outline-light">
                See How We Help
              </a>
            </div>

            <div class="mt-10 flex items-center gap-6 reveal stagger-4">
              <div class="flex items-center gap-2.5">
                <span class="text-[1.5rem] font-bold tracking-[-0.02em]" style="color: var(--color-gold-light); font-family: var(--font-heading);">200+</span>
                <span class="text-[0.6875rem] font-medium uppercase tracking-[0.06em] leading-tight" style="color: rgba(203,213,225,0.7);">Businesses<br>Trust Us</span>
              </div>
              <div class="w-px h-8" style="background: rgba(255,255,255,0.12);"></div>
              <div class="flex items-center gap-2.5">
                <span class="text-[1.5rem] font-bold tracking-[-0.02em]" style="color: var(--color-gold-light); font-family: var(--font-heading);">$50M+</span>
                <span class="text-[0.6875rem] font-medium uppercase tracking-[0.06em] leading-tight" style="color: rgba(203,213,225,0.7);">Tax Saved<br>for Clients</span>
              </div>
              <div class="w-px h-8 hidden sm:block" style="background: rgba(255,255,255,0.12);"></div>
              <div class="hidden sm:flex items-center gap-2.5">
                <span class="text-[1.5rem] font-bold tracking-[-0.02em]" style="color: var(--color-gold-light); font-family: var(--font-heading);">98%</span>
                <span class="text-[0.6875rem] font-medium uppercase tracking-[0.06em] leading-tight" style="color: rgba(203,213,225,0.7);">Client<br>Retention</span>
              </div>
            </div>
          </div>

          <!-- Right: Cal.com booking card -->
          <div class="lg:col-span-5 reveal stagger-3">
            <div class="rounded-[2px] overflow-hidden" style="background: rgba(255,255,255,0.97); box-shadow: 0 8px 40px rgba(0,0,0,0.2), 0 0 0 1px rgba(255,255,255,0.1);">
              <div class="px-6 py-4" style="background: var(--color-midnight); border-bottom: 2px solid var(--color-gold);">
                <p class="text-[0.75rem] font-semibold tracking-[0.1em] uppercase" style="color: var(--color-gold-light);">
                  Book Your Free Consultation
                </p>
                <p class="text-[0.6875rem] mt-1" style="color: rgba(160,174,192,0.7);">30 minutes · No obligation · Speak with a partner</p>
              </div>
              <div id="cal-hero" style="min-height: 380px; overflow: auto;"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ SERVICES ═══ -->
  <section id="services" class="py-20 md:py-28 lg:py-32" style="background: var(--color-cream);">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-10">
      <div class="text-center mb-16 md:mb-20">
        <div class="overline justify-center mb-4 reveal">How We Help</div>
        <h2 class="reveal stagger-1">
          Save More Tax. Spend<br class="hidden sm:block"> Less Time on Admin.
        </h2>
        <p class="mt-6 text-[0.9375rem] leading-[1.7] max-w-lg mx-auto reveal stagger-2" style="color: var(--color-text-secondary);">
          Every service is tailored to your industry, business structure, and growth stage.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {services.map((service, i) => (
          <div class={`reveal stagger-${i + 1} card card-gold group p-7`}>
            <div class="flex items-center justify-between mb-5">
              <div class="w-10 h-10 rounded-[2px] flex items-center justify-center" style="background: var(--color-gold-subtle); color: var(--color-gold);" set:html={service.icon} />
              <span class="text-[0.625rem] font-semibold tracking-[0.1em]" style="color: var(--color-text-muted);">{service.num}</span>
            </div>
            <h3 class="text-[1rem] font-semibold mb-3" style="color: var(--color-midnight);">{service.title}</h3>
            <p class="text-[0.8125rem] leading-[1.7] mb-5" style="color: var(--color-text-secondary);">{service.description}</p>
            <a href="/contact#booking" class="link-arrow inline-flex items-center gap-2 text-[0.8125rem] font-semibold" style="color: var(--color-gold);">
              Book to Discuss
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ TRUSTED BY ═══ -->
  <section class="py-10 md:py-12" style="background: var(--color-cream-dark); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-10">
      <p class="text-center text-[0.625rem] font-semibold uppercase tracking-[0.16em] mb-7 reveal" style="color: var(--color-text-muted);">
        Trusted by leading Sydney businesses
      </p>
      <div class="flex flex-wrap justify-center items-center gap-y-3 max-w-4xl mx-auto reveal-fade">
        <span class="px-5 md:px-7 text-[0.8rem] font-bold uppercase tracking-[0.1em] cursor-default" style="color: var(--color-text-muted);">Harbour Construction</span>
        <span class="hidden sm:block w-px h-3.5" style="background: var(--color-border);"></span>
        <span class="px-5 md:px-7 text-[0.95rem] font-light italic cursor-default" style="color: var(--color-text-muted); font-family: var(--font-heading);">Meridian Property</span>
        <span class="hidden sm:block w-px h-3.5" style="background: var(--color-border);"></span>
        <span class="px-5 md:px-7 text-[0.8rem] font-medium cursor-default" style="color: var(--color-text-muted);">Coastal Dining Co</span>
        <span class="hidden sm:block w-px h-3.5" style="background: var(--color-border);"></span>
        <span class="px-5 md:px-7 text-[0.75rem] font-bold uppercase tracking-[0.06em] cursor-default" style="color: var(--color-text-muted);">TechBridge Solutions</span>
        <span class="hidden sm:block w-px h-3.5" style="background: var(--color-border);"></span>
        <span class="px-5 md:px-7 text-[0.85rem] cursor-default" style="color: var(--color-text-muted); font-family: var(--font-heading);">Greenfield Medical</span>
      </div>
    </div>
  </section>

  <!-- ═══ TESTIMONIALS ═══ -->
  <section class="py-20 md:py-28 lg:py-32" style="background: var(--color-white);">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-10">
      <div class="text-center mb-16 md:mb-20">
        <div class="overline justify-center mb-4 reveal">Testimonials</div>
        <h2 class="reveal stagger-1">
          Hear It from Business<br class="hidden sm:block"> Owners Like You
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {testimonials.map((t, i) => (
          <div class={`reveal stagger-${i + 1} card p-7 md:p-8`} style="border-left: 2px solid var(--color-gold);">
            <blockquote>
              <div class="flex gap-1 mb-4">
                {[1,2,3,4,5].map(() => (
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20" style="color: var(--color-gold);"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                ))}
              </div>
              <p class="text-[0.9375rem] leading-[1.8] mb-6 italic" style="color: var(--color-text-primary);">
                &ldquo;{t.quote}&rdquo;
              </p>
              <footer class="flex items-center gap-3 pt-5" style="border-top: 1px solid var(--color-border);">
                <div class="w-9 h-9 rounded-[2px] flex items-center justify-center text-[0.625rem] font-bold tracking-[0.05em]" style="background: var(--color-gold-subtle); color: var(--color-gold);">
                  {t.initials}
                </div>
                <div>
                  <p class="text-[0.8125rem] font-semibold" style="color: var(--color-midnight);">{t.name}</p>
                  <p class="text-[0.6875rem]" style="color: var(--color-text-secondary);">{t.title}</p>
                </div>
              </footer>
            </blockquote>
          </div>
        ))}
      </div>

      <div class="text-center mt-12 reveal">
        <a href="/contact#booking" class="btn-outline inline-flex items-center gap-2">
          Book Your Free Consultation
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ INSIGHTS ═══ -->
  <section class="py-20 md:py-28 lg:py-32" style="background: var(--color-cream);">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-10">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 md:mb-20 gap-4">
        <div>
          <div class="overline mb-4 reveal">From Our Blog</div>
          <h2 class="reveal stagger-1">Latest Insights</h2>
        </div>
        <a href="/insights" class="reveal link-arrow inline-flex items-center gap-2 text-[0.8125rem] font-semibold" style="color: var(--color-gold);">
          View All
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {articles.map((article, i) => (
          <article class={`reveal stagger-${i + 1} card blog-card group overflow-hidden`}>
            <div class="aspect-[16/10] overflow-hidden relative">
              <img src={article.image} alt={article.alt} class="w-full h-full object-cover" loading="lazy" />
              <span class="absolute top-4 left-4 text-[0.5625rem] font-semibold uppercase tracking-[0.12em] px-2.5 py-[4px] rounded-[2px]" style={`background: ${article.category === 'Tax' ? 'var(--color-gold)' : 'var(--color-midnight)'}; color: #fff;`}>
                {article.category}
              </span>
            </div>
            <div class="p-6">
              <h3 class="text-[1rem] font-semibold mb-2 leading-[1.35]" style="color: var(--color-midnight);">{article.title}</h3>
              <p class="text-[0.8125rem] mb-4 line-clamp-2 leading-[1.7]" style="color: var(--color-text-secondary);">{article.excerpt}</p>
              <div class="flex items-center justify-between pt-3.5" style="border-top: 1px solid var(--color-border);">
                <div class="flex items-center gap-2">
                  <span class="text-[0.6875rem]" style="color: var(--color-text-muted);">{article.date}</span>
                  <span class="w-1 h-1 rounded-full" style="background: var(--color-border);"></span>
                  <span class="text-[0.6875rem]" style="color: var(--color-text-muted);">{article.readTime}</span>
                </div>
                <span class="inline-flex items-center gap-1.5 text-[0.8125rem] font-semibold" style="color: var(--color-gold);">
                  Read
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </span>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <section class="relative py-20 md:py-28 overflow-hidden" style="background: var(--color-midnight);">
    <div class="absolute inset-0 opacity-[0.1]" style="background-image: url('https://images.unsplash.com/photo-1506973035872-a4ec16b8e8d9?w=1600&h=900&fit=crop'); background-size: cover; background-position: center;"></div>

    <div class="relative max-w-[600px] mx-auto px-6 lg:px-10 text-center">
      <div class="overline justify-center mb-4 reveal" style="color: var(--color-gold-light);">
        <span style="background: var(--color-gold-light);" class="w-5 h-[1.5px] inline-block"></span>
        Get Started
      </div>
      <h2 class="mb-5 reveal stagger-1" style="color: #fff;">
        Find Out How Much<br class="hidden sm:block"> You Could Be Saving
      </h2>
      <p class="text-[0.9375rem] leading-[1.75] mb-10 reveal stagger-2" style="color: rgba(160, 174, 192, 0.85);">
        Book a free 30-minute consultation with a senior partner. No obligation, no jargon — just clear, actionable advice tailored to your situation.
      </p>
      <div class="reveal stagger-3">
        <a href="/contact#booking" class="btn-primary">
          Book a Free Consultation
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
      <p class="mt-8 text-[0.6875rem] tracking-[0.04em] reveal stagger-4" style="color: rgba(160, 174, 192, 0.5);">
        Free 30-minute session · No credit card · Speak directly with a partner
      </p>
    </div>
  </section>

  <Footer />

  <script>
    // Cal.com embed — hero widget
    (function (C, A, L) {
      let p = function (a, ar) { a.q.push(ar); };
      let d = C.document;
      C.Cal = C.Cal || function () {
        let cal = C.Cal;
        let ar = arguments;
        if (!cal.loaded) {
          cal.ns = {};
          cal.q = cal.q || [];
          d.head.appendChild(d.createElement("script")).src = A;
          cal.loaded = true;
        }
        if (ar[0] === L) {
          const api = function () { p(api, arguments); };
          const namespace = ar[1];
          api.q = api.q || [];
          typeof namespace === "string" ? (cal.ns[namespace] = api) && p(api, ar) : p(cal, ar);
          return;
        }
        p(cal, ar);
      };
    })(window, "https://app.cal.com/embed/embed.js", "init");

    Cal("init", { origin: "https://cal.com" });
    Cal("inline", {
      calLink: "alister-maddrell-rmtqo9/consultation",
      elementOrSelector: "#cal-hero",
      config: { theme: "light", styles: { branding: { brandColor: "#B8860B" } } }
    });
    Cal("ui", { hideEventTypeDetails: false });
  </script>
</Layout>
