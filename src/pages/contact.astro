  <Footer />

  <script>
    // Cal.com fallback — show mock calendar if embed doesn't load within 3s
    setTimeout(() => {
      const calBooking = document.getElementById('cal-booking');
      const calFallback = document.getElementById('cal-fallback');
      if (calBooking && calFallback) {
        const iframe = calBooking.querySelector('iframe');
        if (!iframe) {
          calBooking.classList.add('hidden');
          calFallback.classList.remove('hidden');
        }
      }
    }, 3000);

    // Form submission handler
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const successMsg = document.getElementById('form-success');

    if (form) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();

        if (!form.checkValidity()) {
          form.reportValidity();
          return;
        }

        if (successMsg) {
          successMsg.classList.remove('hidden');
          form.reset();
          successMsg.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
      });
    }
  </script>
