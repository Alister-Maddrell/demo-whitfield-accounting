---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const partners = [
  {
    name: 'James Whitfield',
    title: 'Managing Partner',
    quals: 'B.Com, CPA, CTA',
    specialty: 'Business structuring, M&A advisory, and high-net-worth tax strategies.',
    image: 'https://images.unsplash.com/photo-1560250097-0b93528c311a?w=400&h=500&fit=crop',
    alt: 'James Whitfield, Managing Partner',
    initials: 'JW',
  },
  {
    name: 'Catherine Nguyen',
    title: 'Partner, Tax',
    quals: 'B.Bus, CA, CTA',
    specialty: 'Proactive tax planning, trust and SMSF taxation specialist.',
    image: 'https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=400&h=500&fit=crop',
    alt: 'Catherine Nguyen, Partner',
    initials: 'CN',
  },
  {
    name: 'Daniel Morrison',
    title: 'Partner, Advisory',
    quals: 'MBA, CPA',
    specialty: 'Cash flow forecasting, growth strategy, and financial modelling.',
    image: 'https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=400&h=500&fit=crop',
    alt: 'Daniel Morrison, Partner',
    initials: 'DM',
  },
];
---

<Layout title="Book a Free Consultation | Whitfield & Associates" description="Book your free 30-minute consultation with a senior Sydney CPA. Clear tax advice, business structuring guidance, and a plan to save more.">
  <Navbar />

  <!-- PAGE HEADER -->
  <section class="relative pt-28 pb-12 md:pt-36 md:pb-16" style="background: var(--color-cream-dark);">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-10">
      <div class="overline mb-4 reveal">Get In Touch</div>
      <h1 class="reveal stagger-1 max-w-xl">
        Book Your Free<br class="hidden sm:block"> Consultation
      </h1>
      <p class="text-[1.0625rem] leading-[1.75] max-w-lg mt-5 reveal stagger-2" style="color: var(--color-text-secondary);">
        Pick a time that suits you. A senior partner will confirm within 2 hours — no juniors, no runaround.
      </p>
      <div class="mt-5 reveal stagger-3">
        <span class="inline-flex items-center gap-2 px-3.5 py-2 rounded-[2px] text-[0.6875rem] font-semibold tracking-[0.04em]" style="background: var(--color-gold-subtle); color: var(--color-gold); border: 1px solid rgba(184,134,11,0.12);">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8"/><path d="M12 18V6"/></svg>
          First consultation free · 30 minutes
        </span>
      </div>
    </div>
  </section>

  <!-- CAL.COM BOOKING -->
  <section id="booking" class="py-16 md:py-24" style="background: var(--color-cream);">
    <div class="max-w-[900px] mx-auto px-6 lg:px-10">
      <div class="text-center mb-10 reveal">
        <div class="overline justify-center mb-4">Schedule Online</div>
        <h2 class="mb-3">Pick a Time That Works</h2>
        <p class="text-[0.9375rem] leading-[1.7] max-w-lg mx-auto" style="color: var(--color-text-secondary);">
          Choose your preferred time below. A senior partner will confirm within 2 hours.
        </p>
      </div>
      <div id="cal-embed" class="reveal" style="width:100%; min-height:500px; overflow:auto; border: 1px solid var(--color-border); border-radius: 2px; background: var(--color-white);"></div>
    </div>
  </section>

  <!-- TEAM + FORM -->
  <section class="py-16 md:py-24" style="background: var(--color-white); border-top: 1px solid var(--color-border);">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
        <!-- Form -->
        <div class="lg:col-span-7 reveal">
          <div class="flex items-center gap-3 mb-8">
            <div class="w-10 h-10 rounded-[2px] flex items-center justify-center" style="background: var(--color-gold-subtle);">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-gold);"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div>
              <h3 class="text-[1rem] font-semibold" style="color: var(--color-midnight);">Or Send Us a Message</h3>
              <p class="text-[0.75rem]" style="color: var(--color-text-muted);">We respond within one business day</p>
            </div>
          </div>

          <form action="https://formspree.io/f/placeholder" method="POST" id="contact-form" class="space-y-6" style="border: 1px solid var(--color-border); border-radius: 2px; padding: 2rem; background: var(--color-white); box-shadow: var(--shadow-card);">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="name" class="block text-[0.8125rem] font-semibold mb-2" style="color: var(--color-midnight);">Full Name <span style="color: var(--color-gold);">*</span></label>
                <input type="text" id="name" name="name" required placeholder="Your full name" class="w-full px-4 py-3 text-[0.875rem] border rounded-[2px]" style="border-color: var(--color-border);" />
              </div>
              <div>
                <label for="email" class="block text-[0.8125rem] font-semibold mb-2" style="color: var(--color-midnight);">Email <span style="color: var(--color-gold);">*</span></label>
                <input type="email" id="email" name="email" required placeholder="you@company.com" class="w-full px-4 py-3 text-[0.875rem] border rounded-[2px]" style="border-color: var(--color-border);" />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="phone" class="block text-[0.8125rem] font-semibold mb-2" style="color: var(--color-midnight);">Phone <span style="color: var(--color-gold);">*</span></label>
                <input type="tel" id="phone" name="phone" required placeholder="04XX XXX XXX" class="w-full px-4 py-3 text-[0.875rem] border rounded-[2px]" style="border-color: var(--color-border);" />
              </div>
              <div>
                <label for="service" class="block text-[0.8125rem] font-semibold mb-2" style="color: var(--color-midnight);">Service Interest <span style="color: var(--color-gold);">*</span></label>
                <select id="service" name="service" required class="w-full px-4 py-3 text-[0.875rem] border rounded-[2px] bg-white appearance-none" style="border-color: var(--color-border); background-image: url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2212%22 height=%2212%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22%23718096%22 stroke-width=%222%22><polyline points=%226 9 12 15 18 9%22/></svg>'); background-repeat: no-repeat; background-position: right 16px center;">
                  <option value="">Select a service...</option>
                  <option value="Tax Planning">Tax Planning & Compliance</option>
                  <option value="Business Advisory">Business Advisory</option>
                  <option value="Bookkeeping">Bookkeeping & Payroll</option>
                  <option value="SMSF">Self-Managed Super Fund</option>
                  <option value="General">General Enquiry</option>
                </select>
              </div>
            </div>

            <div>
              <label for="message" class="block text-[0.8125rem] font-semibold mb-2" style="color: var(--color-midnight);">Message</label>
              <textarea id="message" name="message" rows="4" placeholder="Tell us about your situation..." class="w-full px-4 py-3 text-[0.875rem] border rounded-[2px] resize-y" style="border-color: var(--color-border);"></textarea>
            </div>

            <div class="flex items-center gap-4">
              <button type="submit" class="btn-primary">
                Send Message
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </button>
              <span class="text-[0.6875rem] hidden sm:block" style="color: var(--color-text-muted);">Response within 24 hours</span>
            </div>

            <div id="form-success" class="hidden p-4 rounded-[2px] text-[0.875rem] font-medium" style="background: var(--color-gold-subtle); color: var(--color-midnight); border: 1px solid rgba(184,134,11,0.15);">
              <strong>Thank you.</strong> We'll be in touch within one business day.
            </div>
          </form>
        </div>

        <!-- Team -->
        <div class="lg:col-span-5 reveal stagger-2">
          <div class="lg:sticky lg:top-[100px]">
            <div class="overline mb-4">Our Team</div>
            <h2 class="mb-3" style="font-size: clamp(1.4rem, 2vw + 0.6rem, 2rem);">
              You'll Speak with a Partner
            </h2>
            <p class="text-[0.8125rem] leading-[1.7] mb-8" style="color: var(--color-text-secondary);">
              Every consultation is led by a CPA-qualified partner with 15+ years of experience.
            </p>

            <div class="space-y-4">
              {partners.map((p) => (
                <div class="card group flex gap-4 items-start p-4">
                  <div class="w-[80px] h-[96px] flex-shrink-0 rounded-[2px] overflow-hidden team-frame">
                    <img src={p.image} alt={p.alt} class="w-full h-full object-cover" loading="lazy" />
                  </div>
                  <div class="pt-0.5">
                    <h3 class="text-[0.875rem] font-semibold leading-tight" style="color: var(--color-midnight);">{p.name}</h3>
                    <p class="text-[0.6875rem] font-semibold mt-0.5" style="color: var(--color-gold);">{p.title}</p>
                    <p class="text-[0.625rem] mt-0.5" style="color: var(--color-text-muted);">{p.quals}</p>
                    <p class="text-[0.75rem] mt-2 leading-[1.6]" style="color: var(--color-text-secondary);">{p.specialty}</p>
                  </div>
                </div>
              ))}
            </div>

            <div class="mt-6 p-4 rounded-[2px]" style="background: var(--color-cream); border: 1px solid var(--color-border);">
              <p class="text-[0.6875rem] font-semibold uppercase tracking-[0.1em] mb-3" style="color: var(--color-text-muted);">Prefer to call?</p>
              <a href="tel:0295557800" class="flex items-center gap-2.5 text-[0.875rem] font-medium mb-2" style="color: var(--color-midnight);">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color: var(--color-gold);"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.12.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.58 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                02 9555 7800
              </a>
              <a href="mailto:enquiries@whitfieldassociates.com.au" class="flex items-center gap-2.5 text-[0.8125rem] font-medium" style="color: var(--color-midnight);">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color: var(--color-gold);"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                enquiries@whitfieldassociates.com.au
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- OFFICE -->
  <section class="py-16 md:py-24" style="background: var(--color-cream);">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-10">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-16 items-start">
        <div class="reveal">
          <div class="overline mb-4">Visit Us</div>
          <h2 class="mb-8" style="font-size: clamp(1.4rem, 2vw + 0.6rem, 2rem);">Our Office</h2>
          <div class="space-y-5 text-[0.875rem]" style="color: var(--color-text-primary);">
            <p><strong>Address:</strong> Level 12, 60 Castlereagh Street, Sydney NSW 2000</p>
            <p><strong>Phone:</strong> <a href="tel:0295557800" style="color: var(--color-gold);">02 9555 7800</a></p>
            <p><strong>Email:</strong> <a href="mailto:enquiries@whitfieldassociates.com.au" style="color: var(--color-gold);">enquiries@whitfieldassociates.com.au</a></p>
            <p><strong>Hours:</strong> Monday – Friday, 8:30am – 5:30pm</p>
            <p class="text-[0.8125rem] p-3.5 rounded-[2px]" style="color: var(--color-text-secondary); background: var(--color-cream-dark); border: 1px solid var(--color-border);">
              Located on Level 12. Enter via the main lobby on Castlereagh Street.
            </p>
          </div>
        </div>
        <div class="reveal stagger-2 rounded-[2px] overflow-hidden" style="box-shadow: var(--shadow-card);">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3312.8!2d151.2085!3d-33.871!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x6b12ae3f3f3f3f3f%3A0x0!2s60+Castlereagh+St%2C+Sydney+NSW+2000!5e0!3m2!1sen!2sau!4v1700000000000!5m2!1sen!2sau"
            width="100%"
            height="400"
            style="border:0;"
            allowfullscreen
            loading="lazy"
            title="Office location"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

  <Footer />

  <script>
    // Cal.com
    (function (C, A, L) {
      let p = function (a, ar) { a.q.push(ar); };
      let d = C.document;
      C.Cal = C.Cal || function () {
        let cal = C.Cal;
        let ar = arguments;
        if (!cal.loaded) {
          cal.ns = {};
          cal.q = cal.q || [];
          d.head.appendChild(d.createElement("script")).src = A;
          cal.loaded = true;
        }
        if (ar[0] === L) {
          const api = function () { p(api, arguments); };
          const namespace = ar[1];
          api.q = api.q || [];
          typeof namespace === "string" ? (cal.ns[namespace] = api) && p(api, ar) : p(cal, ar);
          return;
        }
        p(cal, ar);
      };
    })(window, "https://app.cal.com/embed/embed.js", "init");

    Cal("init", { origin: "https://cal.com" });
    Cal("inline", {
      calLink: "alister-maddrell-rmtqo9/consultation",
      elementOrSelector: "#cal-embed",
      config: { theme: "light", styles: { branding: { brandColor: "#B8860B" } } }
    });
    Cal("ui", { hideEventTypeDetails: false });

    // Form handler
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const successMsg = document.getElementById('form-success');
    if (form) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        if (!form.checkValidity()) { form.reportValidity(); return; }
        if (successMsg) {
          successMsg.classList.remove('hidden');
          form.reset();
          successMsg.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
      });
    }
  </script>
</Layout>
