---

---

<footer class="relative" style="background: var(--color-bg-dark);">
  <!-- Top emerald accent line -->
  <div class="h-[3px] w-full" style="background: var(--color-emerald);"></div>

  <div class="max-w-[1200px] mx-auto px-6 lg:px-10">
    <!-- Main footer content -->
    <div class="pt-24 pb-20 lg:pt-28 lg:pb-24">
      <!-- Top row: brand + tagline -->
      <div class="mb-14 lg:mb-16">
        <a href="/" class="no-underline inline-block">
          <span class="text-[1.4rem] font-bold tracking-[-0.01em]" style="font-family: var(--font-heading); color: #fff;">
            Whitfield<span style="color: var(--color-emerald-light);">&amp;</span>Associates
          </span>
        </a>
        <p class="mt-3 text-[0.875rem] leading-relaxed max-w-sm" style="color: rgba(203, 213, 225, 0.85);">
          Helping Sydney business owners keep more of what they earn since 2008. CPA-qualified partners, proactive tax strategies, and genuine care for your success.
        </p>
      </div>

      <!-- Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">
        <!-- Services -->
        <div>
          <h4 class="text-[0.6875rem] font-semibold uppercase tracking-[0.14em] mb-5" style="color: var(--color-emerald-light); font-family: var(--font-body);">Services</h4>
          <ul class="space-y-3">
            {['Tax Planning & Compliance', 'Business Advisory', 'Bookkeeping & Payroll', 'Self-Managed Super Funds'].map(item => (
              <li>
                <span class="text-[0.8125rem]" style="color: rgba(203, 213, 225, 0.8);">{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Quick Links -->
        <div>
          <h4 class="text-[0.6875rem] font-semibold uppercase tracking-[0.14em] mb-5" style="color: var(--color-emerald-light); font-family: var(--font-body);">Quick Links</h4>
          <ul class="space-y-3">
            {[
              { name: 'Home', href: '/' },
              { name: 'Insights & Resources', href: '/insights' },
              { name: 'Book a Consultation', href: '/contact' },
            ].map(link => (
              <li>
                <a href={link.href} class="text-[0.8125rem] no-underline transition-colors duration-300 hover:text-white" style="color: rgba(203, 213, 225, 0.8);">
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Contact Details -->
        <div>
          <h4 class="text-[0.6875rem] font-semibold uppercase tracking-[0.14em] mb-5" style="color: var(--color-emerald-light); font-family: var(--font-body);">Contact</h4>
          <ul class="space-y-3 text-[0.8125rem]" style="color: rgba(203, 213, 225, 0.8);">
            <li>Level 12, 60 Castlereagh Street<br>Sydney NSW 2000</li>
            <li>
              <a href="tel:0295557800" class="no-underline transition-colors duration-300 hover:text-white" style="color: rgba(203, 213, 225, 0.8);">
                02 9555 7800
              </a>
            </li>
            <li>
              <a href="mailto:enquiries@whitfieldassociates.com.au" class="no-underline transition-colors duration-300 hover:text-white break-all" style="color: rgba(203, 213, 225, 0.8);">
                enquiries@whitfieldassociates.com.au
              </a>
            </li>
            <li>Monday – Friday, 8:30am – 5:30pm</li>
          </ul>
        </div>

        <!-- Professional Memberships -->
        <div>
          <h4 class="text-[0.6875rem] font-semibold uppercase tracking-[0.14em] mb-5" style="color: var(--color-emerald-light); font-family: var(--font-body);">Memberships</h4>
          <ul class="space-y-2.5">
            {['CPA Australia', 'Chartered Accountants ANZ', 'Tax Practitioners Board'].map(m => (
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full flex-shrink-0" style="background: var(--color-emerald);"></span>
                <span class="text-[0.8125rem]" style="color: rgba(203, 213, 225, 0.8);">{m}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="py-8 flex flex-col md:flex-row justify-between items-center gap-3" style="border-top: 1px solid rgba(255,255,255,0.08);">
      <p class="text-[0.6875rem] tracking-[0.01em]" style="color: rgba(148, 163, 184, 0.7);">
        &copy; 2026 Whitfield &amp; Associates. All rights reserved. ABN 33 456 789 012
      </p>
      <p class="text-[0.6875rem] tracking-[0.01em]" style="color: rgba(148, 163, 184, 0.7);">
        60 Castlereagh Street, Sydney NSW 2000
      </p>
    </div>
  </div>
</footer>
