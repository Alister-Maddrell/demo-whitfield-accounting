---
---

<footer style="background: var(--color-midnight);">
  <div class="h-[2px] w-full" style="background: linear-gradient(90deg, var(--color-gold), var(--color-gold-light), var(--color-gold));"></div>

  <div class="max-w-[1200px] mx-auto px-6 lg:px-10">
    <div class="pt-20 pb-16 lg:pt-24 lg:pb-20">
      <!-- Brand -->
      <div class="mb-12 lg:mb-14">
        <a href="/" class="inline-block">
          <span class="text-[1.3rem] font-semibold tracking-[-0.01em]" style="font-family: var(--font-heading); color: #fff;">
            Whitfield<span style="color: var(--color-gold-light);">&</span>Associates
          </span>
        </a>
        <p class="mt-3 text-[0.875rem] leading-relaxed max-w-sm" style="color: rgba(160, 174, 192, 0.8);">
          Helping Sydney business owners keep more of what they earn since 2008. CPA-qualified partners, proactive tax strategies.
        </p>
      </div>

      <!-- Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">
        <div>
          <h4 class="text-[0.6875rem] font-semibold uppercase tracking-[0.14em] mb-5" style="color: var(--color-gold-light); font-family: var(--font-body);">Services</h4>
          <ul class="space-y-3">
            {['Tax Planning & Compliance', 'Business Advisory', 'Bookkeeping & Payroll', 'Self-Managed Super Funds'].map(item => (
              <li><span class="text-[0.8125rem]" style="color: rgba(160, 174, 192, 0.75);">{item}</span></li>
            ))}
          </ul>
        </div>

        <div>
          <h4 class="text-[0.6875rem] font-semibold uppercase tracking-[0.14em] mb-5" style="color: var(--color-gold-light); font-family: var(--font-body);">Quick Links</h4>
          <ul class="space-y-3">
            {[
              { name: 'Home', href: '/' },
              { name: 'Insights', href: '/insights' },
              { name: 'Book a Consultation', href: '/contact#booking' },
            ].map(link => (
              <li>
                <a href={link.href} class="text-[0.8125rem] transition-colors duration-300 hover:text-white" style="color: rgba(160, 174, 192, 0.75);">
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <h4 class="text-[0.6875rem] font-semibold uppercase tracking-[0.14em] mb-5" style="color: var(--color-gold-light); font-family: var(--font-body);">Contact</h4>
          <ul class="space-y-3 text-[0.8125rem]" style="color: rgba(160, 174, 192, 0.75);">
            <li>Level 12, 60 Castlereagh Street<br>Sydney NSW 2000</li>
            <li><a href="tel:0295557800" class="transition-colors duration-300 hover:text-white" style="color: rgba(160, 174, 192, 0.75);">02 9555 7800</a></li>
            <li><a href="mailto:enquiries@whitfieldassociates.com.au" class="transition-colors duration-300 hover:text-white break-all" style="color: rgba(160, 174, 192, 0.75);">enquiries@whitfieldassociates.com.au</a></li>
            <li>Monday – Friday, 8:30am – 5:30pm</li>
          </ul>
        </div>

        <div>
          <h4 class="text-[0.6875rem] font-semibold uppercase tracking-[0.14em] mb-5" style="color: var(--color-gold-light); font-family: var(--font-body);">Memberships</h4>
          <ul class="space-y-2.5">
            {['CPA Australia', 'Chartered Accountants ANZ', 'Tax Practitioners Board'].map(m => (
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full flex-shrink-0" style="background: var(--color-gold);"></span>
                <span class="text-[0.8125rem]" style="color: rgba(160, 174, 192, 0.75);">{m}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <div class="py-7 flex flex-col md:flex-row justify-between items-center gap-3" style="border-top: 1px solid rgba(255,255,255,0.06);">
      <p class="text-[0.6875rem]" style="color: rgba(160, 174, 192, 0.5);">
        &copy; 2026 Whitfield & Associates. All rights reserved. ABN 33 456 789 012
      </p>
      <p class="text-[0.6875rem]" style="color: rgba(160, 174, 192, 0.5);">
        60 Castlereagh Street, Sydney NSW 2000
      </p>
    </div>
  </div>
</footer>
