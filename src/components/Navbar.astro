---
const currentPath = Astro.url.pathname;
const links = [
  { name: 'Home', href: '/' },
  { name: 'Insights', href: '/insights' },
  { name: 'Contact', href: '/contact' },
];
---

<div class="nav-wrap" id="nav-wrap">
  <nav class="nav-bar" id="main-nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">
        Whitfield<span class="nav-logo-amp">&</span>Associates
      </a>

      <div class="nav-links hidden md:flex">
        {links.map(link => (
          <a href={link.href} class={`nav-link ${currentPath === link.href ? 'active' : ''}`}>
            {link.name}
          </a>
        ))}
      </div>

      <div class="hidden md:flex items-center gap-3">
        <a href="/contact#booking" class="nav-cta">
          Book Consultation
        </a>
      </div>

      <button class="nav-burger md:hidden" id="mobile-menu-btn" aria-label="Open menu">
        <span class="burger-line"></span>
        <span class="burger-line"></span>
        <span class="burger-line"></span>
      </button>
    </div>

    <div class="nav-mobile md:hidden" id="mobile-menu">
      <div class="nav-mobile-inner">
        {links.map(link => (
          <a href={link.href} class="nav-mobile-link">{link.name}</a>
        ))}
        <div class="nav-mobile-divider"></div>
        <a href="/contact#booking" class="nav-cta nav-cta-mobile">
          Book Consultation
        </a>
      </div>
    </div>
  </nav>
</div>
